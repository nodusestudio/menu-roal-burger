rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Catálogo público (solo lectura sin auth) ───────────────────────────
    // El menú digital lee estas colecciones sin autenticación.
    match /configuracion/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /categorias/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /productos/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /botones/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /bebidas/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /acompanantes/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /promociones/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /combos_especiales/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /promos_2x1/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── Pedidos ────────────────────────────────────────────────────────────
    // Clientes pueden crear y leer sus pedidos (tracking público).
    // Solo el admin puede actualizar o eliminar.
    match /pedidos/{doc} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ─── Mensajes de contacto ───────────────────────────────────────────────
    // Clientes pueden enviar mensajes. Admin los lee y gestiona.
    match /mensajes/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ─── Clientes ───────────────────────────────────────────────────────────
    // El menú puede crear y actualizar el perfil del cliente (direcciones).
    // Solo admin puede eliminar.
    match /clientes/{doc} {
      allow create, update: if true;
      allow read, delete: if request.auth != null;
    }

    // ─── Solo admin ─────────────────────────────────────────────────────────
    match /resumen_ventas/{doc} {
      allow read, write: if request.auth != null;
    }
    match /admin_estado/{doc} {
      allow read, write: if request.auth != null;
    }
    match /cierres_caja/{doc} {
      allow read, write: if request.auth != null;
    }
    match /pos_tickets/{doc} {
      allow read, write: if request.auth != null;
    }
    match /gastos_caja/{doc} {
      allow read, write: if request.auth != null;
    }
    match /proveedores/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
